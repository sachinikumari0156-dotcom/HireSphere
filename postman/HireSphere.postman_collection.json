{
  "info": {
    "name": "HireSphere API",
    "description": "Sanitized Postman collection for HireSphere coursework. Use placeholder credentials only.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5167/api" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Candidate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"Candidate\",\n  \"email\": \"{{candidateEmail}}\",\n  \"password\": \"{{candidatePassword}}\",\n  \"confirmPassword\": \"{{candidatePassword}}\",\n  \"acceptTerms\": true\n}"
            },
            "url": "{{baseUrl}}/auth/register/candidate"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  if (json.token) { pm.collectionVariables.set('accessToken', json.token); }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Candidate",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/candidate/dashboard"
          }
        },
        {
          "name": "Jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/candidate/jobs"
          }
        }
      ]
    },
    {
      "name": "Recruiter",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/recruiter/dashboard"
          }
        },
        {
          "name": "Jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/recruiter/jobs"
          }
        }
      ]
    },
    {
      "name": "Hiring Manager",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/hiring-manager/dashboard"
          }
        }
      ]
    },
    {
      "name": "Administrator",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/dashboard"
          }
        },
        {
          "name": "Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Audit Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/audit-logs"
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "AI Provider Status (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/integrations/ai/status"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Preferences",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/notifications/preferences"
          }
        }
      ]
    },
    {
      "name": "Calendar",
      "item": [
        {
          "name": "Integration Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/integrations/status"
          }
        }
      ]
    },
    {
      "name": "Storage",
      "item": [
        {
          "name": "Storage Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/storage/status"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Swagger OpenAPI",
          "request": {
            "method": "GET",
            "url": "http://localhost:5167/swagger/v1/swagger.json"
          }
        }
      ]
    }
  ]
}
